# GradeCraft Environment Configuration
# Copia questo file in .env e inserisci le tue credenziali reali
# Il file .env è già in .gitignore e non verrà committato

# Credenziali Classeviva
CVV_USERNAME=tuo.email@scuola.it
CVV_PASSWORD=la_tua_password

# Anno scolastico (es: 24 per 2024-2025)
CLASSEVIVA_YEAR=24

# Impostazioni Debug
API_DETACH=false  # true per disabilitare chiamate reali (testing)
DEBUG=false       # true per abilitare output di debug
